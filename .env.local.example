# Copy this file to ".env.local" and fill in your real Veracity LRS values.
# .env.local is git-ignored and is read by `vercel dev` locally.
# In production, set these same three variables in the Vercel dashboard:
#   Project → Settings → Environment Variables
#
# These are read ONLY inside /api/track.js at runtime. They must NEVER appear
# in any client-side file (anything under /src, index.html, etc.).

# The LRS statements endpoint (note the trailing /statements).
VERACITY_ENDPOINT=https://YOUR-LRS-NAME.lrs.io/xapi/statements

# LRS basic-auth key (acts as the username).
VERACITY_KEY=your-lrs-key

# LRS basic-auth secret (acts as the password).
VERACITY_SECRET=your-lrs-secret
